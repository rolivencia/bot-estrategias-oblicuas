{
  "name": "bot-estrategias-oblicuas",
  "version": "1.0.0",
  "main": "src/bot.ts",
  "type": "module",
  "author": "Ramiro Olivencia",
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/bot.ts",
    "lint": "npm run lint:base 'src/**'",
    "lint:base": "eslint --ext .js,.json,.ts",
    "prettify": "npx prettier --write .",
    "start": "tsx src/bot.ts",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "src/**/*.{ts,js,json}": [
      "npm run lint:base --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run typecheck && lint-staged"
    }
  },
  "devDependencies": {
    "@types/cron": "^2.4.3",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "browserslist": ">=4.16.5",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-prettier": "^5.5.5",
    "glob-parent": ">=5.1.2",
    "hosted-git-info": ">=2.8.9",
    "husky": "^4.3.8",
    "lint-staged": "^10.5.3",
    "path-parse": ">=1.0.7",
    "prettier": "^3.8.3",
    "semver-regex": ">=3.1.3",
    "trim-newlines": ">=3.0.1",
    "typescript": "^6.0.3",
    "ws": ">=7.4.6"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "cron": "^3.3.0",
    "dotenv": "^16.4.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "tsx": "^4.19.0",
    "twitter-api-v2": "^1.15.2"
  }
}
